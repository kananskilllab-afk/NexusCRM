# ─────────────────────────────────────────────────────────────────────────────
# NexusCRM server environment — copy to ".env" and fill in real values.
# Never commit the real .env. Values shown are placeholders / safe defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nexuscrm
JWT_SECRET=change-me-to-a-long-random-string
PORT=5000
# Public base URL of this API (used for email tracking pixel / share links)
APP_URL=http://localhost:5000

# ── Email / SMTP (automated emails, quotes, comms) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL="Kanan Travel" <no-reply@kanan.co>

# ── Finance ──────────────────────────────────────────────────────────────────
# Home state code for GST place-of-supply logic on invoices
HOME_STATE=GJ
# Quote discount above this % is routed to manager approval (Stage 7)
DISCOUNT_THRESHOLD_PCT=10

# ── Automation scheduler (Phase 2 — SLA / rotting / nurturing) ───────────────
# Set to "false" to disable all background jobs (e.g. in tests).
SCHEDULER_ENABLED=true
# How often the scheduler sweeps, in milliseconds (default 15 min).
SCHEDULER_INTERVAL_MS=900000
# Minutes before an unanswered New lead breaches first-response SLA.
SLA_FIRST_RESPONSE_MIN=30
# Days of no activity before an active lead is auto-moved to Nurturing.
LEAD_STALE_DAYS=7
# Days a Nurturing lead can stay silent before auto-closing as Unqualified.
NURTURE_CAP_DAYS=45

# ── Integrations (Phase 3) ───────────────────────────────────────────────────
# Each adapter runs in safe "stub" mode until its keys are set. Fill these in
# with credentials from your own provider accounts to go live.

# WhatsApp Business API (e.g. Meta Cloud API)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_FROM=

# Payment gateway (e.g. razorpay | stripe)
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_API_SECRET=

# GDS flight inventory (e.g. amadeus | sabre)
GDS_PROVIDER=
GDS_API_URL=
GDS_API_KEY=
